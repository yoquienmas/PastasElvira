<Window x:Class="CapaPresentacion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login" Height="250" Width="400">
	<Grid Margin="20">
		<StackPanel>
			<TextBlock Text="Usuario:"/>
			<TextBox Name="txtUsuario" Margin="0,0,0,10"/>

			<TextBlock Text="Contraseña:"/>
			<PasswordBox Name="txtClave" Margin="0,0,0,20"/>

			<Button Content="Ingresar" Width="100" Click="BtnIngresar_Click"/>
		</StackPanel>
	</Grid>
</Window>

